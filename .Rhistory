fill = NA,
linewidth = 0.4,
show.legend = TRUE
) +
fill_scale +
colour_scale +
labs(title = "(a) Priority List") +
guides(
fill   = guide_legend(order = 1),
colour = guide_legend(order = 3, override.aes = list(fill = NA, linewidth = 0.8))
) +
common_theme
# (b) Priority List and Protected area
map_protected2 <- ggplot() +
geom_sf(data = merged_municipios, aes(fill = priority_status), colour = NA) +
ggpattern::geom_sf_pattern(
data = conservation_amazon,
aes(pattern = "Protected area"),   # <- this creates the pattern legend
fill = "white",
colour = NA,
pattern_colour = "black",
pattern_fill = "black",
pattern_size = 0.15,
pattern_spacing = 0.03,
pattern_density = 0.35,
pattern_angle = 45,
pattern_key_scale_factor = 1.2,    # makes stripes easier to see in legend
show.legend = TRUE
) +
geom_sf(
data = amazon_biome,
aes(colour = "Amazon"),
fill = NA,
linewidth = 0.4,
show.legend = TRUE
) +
fill_scale +
pattern_scale +
colour_scale +
labs(title = "(b) Priority List and Protected area") +
guides(
fill    = guide_legend(order = 1),
pattern = guide_legend(order = 2),
colour  = guide_legend(order = 3, override.aes = list(fill = NA, linewidth = 0.8))
) +
common_theme
# Collect all legends at the bottom
final_map <- wrap_plots(
map_status2,
map_protected2,
ncol = 2,
guides = "collect"
)
final_map
